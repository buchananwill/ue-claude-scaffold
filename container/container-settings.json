{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /claude-hooks/intercept_build_test.sh"
          },
          {
            "type": "command",
            "command": "bash /claude-hooks/block-push-passthrough.sh"
          },
          {
            "type": "command",
            "command": "bash /claude-hooks/inject-agent-header.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /claude-hooks/lint-cpp-diff.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /claude-hooks/lint-cpp-diff.py"
          }
        ]
      }
    ]
  }
}
