# Structural configuration (paths, ports, build scripts) lives in
# scaffold.config.json. Only secrets and per-launch parameters belong here.

# ── Authentication ─────────────────────────────────────────────────────────
# Option A: OAuth credentials (Claude Pro/Max subscription)
CLAUDE_CREDENTIALS_PATH=

# Option B: API key (pay-per-token via Anthropic API)
# ANTHROPIC_API_KEY=sk-ant-...

# ── Database ───────────────────────────────────────────────────────────────
# Omit for local PGlite (in-process Postgres), set for external Postgres/Supabase
# DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# ── Per-Launch Parameters ──────────────────────────────────────────────────
# Agent identity
AGENT_NAME=agent-1
WORK_BRANCH=main
# REQUIRED: which agent definition to load (e.g. scaffold-orchestrator, container-orchestrator)
AGENT_TYPE=
MAX_TURNS=200

# ── Worker Mode ────────────────────────────────────────────────────────────
# Set to true to run the container as a task-queue worker
# WORKER_MODE=false
# WORKER_POLL_INTERVAL=30
# WORKER_SINGLE_TASK=true
