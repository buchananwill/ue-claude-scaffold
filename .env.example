# ── Claude Authentication ─────────────────────────────────────────────────────
# Option A: API key (pay-per-token via Anthropic API)
# ANTHROPIC_API_KEY=sk-ant-...
#
# Option B: OAuth credentials (Claude Pro/Max subscription)
# Mount your host credentials file read-only into the container.
# On Windows:  C:\Users\<you>\.claude\.credentials.json
# On macOS:    ~/.claude/.credentials.json
# On Linux:    ~/.claude/.credentials.json
# The docker-compose template mounts this automatically — just set the path:
CLAUDE_CREDENTIALS_PATH=

# ── Unreal Engine ─────────────────────────────────────────────────────────────
# Absolute path to your UE installation (the Engine/ root)
UE_ENGINE_PATH=

# ── Project ───────────────────────────────────────────────────────────────────
# Absolute path to your project's main worktree (the one with the .uproject)
PROJECT_PATH=

# ── Server ────────────────────────────────────────────────────────────────────
# Port for the coordination server
SERVER_PORT=9100

# ── Git / Worktrees ────────────────────────────────────────────────────────
# Absolute path to the local bare repo (intermediary between container and host)
BARE_REPO_PATH=

# Absolute path to the directory containing prompt.md and optional instructions/
TASKS_PATH=

# ── Container Agent ────────────────────────────────────────────────────────
# Path to agent definitions directory (defaults to scaffold's agents/)
# AGENTS_PATH=

# Agent identity and behavior (these have sensible defaults)
AGENT_NAME=agent-1
WORK_BRANCH=main
AGENT_TYPE=container-orchestrator
MAX_TURNS=200

# ── Build / Test ───────────────────────────────────────────────────────────
# Script filenames (not paths) — must match what Claude Code invokes in the container
BUILD_SCRIPT_NAME=build.py
TEST_SCRIPT_NAME=run_tests.py

# Space-separated default test filters (e.g. "MyProject.Tests")
DEFAULT_TEST_FILTERS=
