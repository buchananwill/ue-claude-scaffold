# Structural configuration (paths, ports, build scripts) lives in
# scaffold.config.json. Only secrets and per-launch parameters belong here.

# ── Authentication ─────────────────────────────────────────────────────────
# Option A: OAuth credentials (Claude Pro/Max subscription)
CLAUDE_CREDENTIALS_PATH=

# Option B: API key (pay-per-token via Anthropic API)
# ANTHROPIC_API_KEY=sk-ant-...

# ── Claude Code Plugins (sub-agents, skills, MCP servers) ──────────────────
# Path to your host's Claude Code plugins directory. Required; mounted read-only
# into the container as /host-plugins. Typically ~/.claude/plugins on the host.
CLAUDE_PLUGINS_PATH=

# Comma-separated allowlist of plugin directory names to stage inside the
# container at /home/claude/.claude/plugins. Container's entrypoint copies just
# these subdirectories from the read-only host mount, so FSM role sessions see
# only what you explicitly opt into. Leave empty for a bare Claude Code install
# (default). Suggested starting set for FSM-driven projects:
#   CLAUDE_PLUGINS_ALLOW=superpowers,feature-dev
CLAUDE_PLUGINS_ALLOW=

# ── Database ───────────────────────────────────────────────────────────────
# Omit for local PGlite (in-process Postgres), set for external Postgres/Supabase.
# This scaffold deliberately ignores a user-level DATABASE_URL (which may be
# inherited from a co-installed Supabase project) and only honors the
# namespaced SCAFFOLD_DATABASE_URL knob below.
# SCAFFOLD_DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# ── Per-Launch Parameters ──────────────────────────────────────────────────
# Agent identity
AGENT_NAME=agent-1
# WORK_BRANCH is normally computed by launch.sh as docker/{project-id}/{agent-name}
# Only set this to override the default branch computation.
# WORK_BRANCH=main
# REQUIRED: which agent definition to load (e.g. scaffold-orchestrator, container-orchestrator)
AGENT_TYPE=
# Reasoning effort for the top-level Claude session. Valid: low, medium, high, xhigh, max.
# Resolution order: launch.sh --effort > scaffold.config.json projects.<id>.effort > this > built-in default (high).
# Only affects the top-level session; sub-agents spawned via the Agent tool are not covered yet (see issues/048).
CLAUDE_EFFORT=high
MAX_TURNS=200

# ── Worker Mode ────────────────────────────────────────────────────────────
# Set to true to run the container as a task-queue worker
# WORKER_MODE=false
# WORKER_POLL_INTERVAL=30
# WORKER_SINGLE_TASK=true
