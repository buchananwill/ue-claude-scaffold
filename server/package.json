{
  "name": "@ue-claude/server",
  "version": "0.2.0",
  "description": "Coordination server for running Claude Code agents in Docker against Unreal Engine projects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/buchananwill/ue-claude-scaffold.git",
    "directory": "server"
  },
  "keywords": ["claude", "unreal-engine", "docker", "agent", "coordination"],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/sensible": "^6",
    "better-sqlite3": "^11",
    "fastify": "^5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7",
    "@types/node": "^22",
    "c8": "^11.0.0",
    "tsx": "^4",
    "typescript": "^5.8"
  }
}
