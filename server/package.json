{
  "name": "@ue-claude/server",
  "version": "0.2.0",
  "description": "Coordination server for running Claude Code agents in Docker against Unreal Engine projects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/buchananwill/ue-claude-scaffold.git",
    "directory": "server"
  },
  "keywords": [
    "claude",
    "unreal-engine",
    "docker",
    "agent",
    "coordination"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov tsx --test src/**/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.2",
    "@fastify/sensible": "^6",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5",
    "gray-matter": "^4.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "c8": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4",
    "typescript": "^5.8"
  }
}
