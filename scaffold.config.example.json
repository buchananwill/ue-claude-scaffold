{
  "$schema": "./scaffold.config.schema.json",

  "project": {
    "name": "MyUEProject",
    "path": "",
    "uprojectFile": "MyUEProject.uproject"
  },

  "tasks": {
    "path": ""
  },

  "engine": {
    "path": "",
    "version": "5.7"
  },

  "build": {
    "scriptPath": "Scripts/build.py",
    "testScriptPath": "Scripts/run_tests.py",
    "defaultTestFilters": ["MyProject"],
    "buildTimeoutMs": 660000,
    "testTimeoutMs": 700000
  },

  "plugins": {
    "readOnlyMounts": []
  },

  "container": {
    "agentType": "container-orchestrator",
    "maxTurns": 200,
    "defaultBranch": "main"
  },

  "server": {
    "port": 9100,
    "ubtLockTimeoutMs": 600000,
    "stagingWorktreeRoot": "",
    "bareRepoRoot": "",
    "stagingWorktreePath": "",
    "bareRepoPath": ""
  },

  "claudeMdPatches": {
    "pathRemaps": {
      "D:\\\\Path\\\\On\\\\Host": "/container/path"
    },
    "agentSubstitutions": {
      "host-only-agent": "- **`container-agent` agent** — replacement for container use"
    }
  }
}
