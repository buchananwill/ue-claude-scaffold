{
  "$schema": "./scaffold.config.schema.json",

  "project": {
    "name": "MyUEProject",
    "path": "",
    "uprojectFile": "MyUEProject.uproject"
  },

  "tasks": {
    "path": "",
    "planBranch": "docker/current-root"
  },

  "engine": {
    "path": "",
    "version": "5.7"
  },

  "build": {
    "scriptPath": "Scripts/build.py",
    "testScriptPath": "Scripts/run_tests.py",
    "defaultTestFilters": ["MyProject"],
    "buildTimeoutMs": 660000,
    "testTimeoutMs": 700000,
    "ubtRetryCount": 5,
    "ubtRetryDelayMs": 30000
  },

  "plugins": {
    "readOnlyMounts": [],
    "stagingCopies": [
      {
        "source": "D:\\Path\\To\\Voxel\\Plugin",
        "relativeDest": "Plugins/Voxel"
      }
    ]
  },

  "hooks": {
    "buildIntercept": true,
    "cppLint": true
  },

  "container": {
    "agentType": "container-orchestrator",
    "maxTurns": 200,
    "defaultBranch": "docker/current-root"
  },

  "server": {
    "port": 9100,
    "ubtLockTimeoutMs": 600000,
    "stagingWorktreeRoot": "",
    "bareRepoPath": ""
  },

  "_NOTE": "When 'projects' is present, legacy top-level 'project', 'engine', and 'build' fields are ignored. Both are shown here for illustration only.",

  "projects": {
    "my-ue-game": {
      "name": "MyUEGame",
      "path": "D:\\Projects\\MyUEGame",
      "uprojectFile": "MyUEGame.uproject",
      "bareRepoPath": "D:\\Repos\\my-ue-game.git",
      "tasksPath": "D:\\Projects\\MyUEGame\\tasks",
      "planBranch": "docker/current-root",
      "engine": { "path": "C:\\UE_5.7", "version": "5.7" },
      "build": {
        "scriptPath": "Scripts/build.py",
        "testScriptPath": "Scripts/run_tests.py",
        "buildTimeoutMs": 660000,
        "testTimeoutMs": 700000
      },
      "plugins": {
        "stagingCopies": [
          { "source": "D:\\Path\\To\\Voxel\\Plugin", "relativeDest": "Plugins/Voxel" }
        ]
      },
      "stagingWorktreeRoot": "D:\\Staging\\my-ue-game",
      "hooks": {
        "buildIntercept": true,
        "cppLint": true
      }
    },
    "my-ue-game-dashboard": {
      "name": "MyUEGameDashboard",
      "path": "D:\\Projects\\MyUEGame",
      "bareRepoPath": "D:\\Repos\\my-ue-game.git",
      "tasksPath": "D:\\Projects\\MyUEGame\\dashboard\\tasks"
    },
    "this-scaffold": {
      "name": "UEClaudeScaffold",
      "path": "D:\\Projects\\ue-claude-scaffold",
      "bareRepoPath": "D:\\Repos\\ue-claude-scaffold.git"
    },
    "side-project": {
      "name": "SideProject",
      "path": "D:\\Projects\\side-project",
      "bareRepoPath": "D:\\Repos\\side-project.git",
      "tasksPath": "D:\\Projects\\side-project\\tasks"
    },
    "web-dashboard": {
      "name": "WebDashboard",
      "path": "D:\\Projects\\web-dashboard",
      "bareRepoPath": "D:\\Repos\\web-dashboard.git",
      "hooks": {
        "buildIntercept": false
      }
    }
  }
}
